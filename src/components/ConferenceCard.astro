---
import { conferenceHref } from "../lib/paths";
import type { Lang } from "../lib/paths";
import { t } from "../lib/i18n";

interface Props {
  lang: Lang;
  id: string;
  venue: string;
  year: number;
  title: string;
  overviewStatus: "pending" | "in-progress" | "complete";
  paperCount?: number;
}

const { lang, id, venue, year, title, paperCount } = Astro.props;
const countKey = paperCount === 1 ? "card.papers_count_one" : "card.papers_count_other";
---

<a class="conf-card" data-venue={venue} href={conferenceHref(lang, id)}>
  <div class="venue-row">
    <span class="venue">{venue}</span>
    <span class="year">{year}</span>
  </div>
  <span class="title">{title}</span>
  <span class={`paper-count${!paperCount ? " is-empty" : ""}`}>
    {paperCount && paperCount > 0
      ? t(lang, countKey, { n: paperCount })
      : t(lang, "card.papers_count_other", { n: 0 })}
  </span>
</a>
