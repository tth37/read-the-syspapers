---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { LANGS } from "../../lib/paths";
import type { Lang } from "../../lib/paths";
import { t } from "../../lib/i18n";

export async function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
---

<BaseLayout title={t(lang, "about.title")} lang={lang}>
  <h1>{t(lang, "about.title")}</h1>
  {lang === "en" ? (
    <section class="prose">
      <p>
        <strong>read-the-syspapers</strong> is a personal, static site hosting PhD-depth summaries of
        papers from systems top conferences (OSDI, SOSP, NSDI, ATC, EuroSys, ASPLOS, FAST, MLSys,
        and more).
      </p>
      <p>
        Summaries are produced by coding agents (Claude Code, Codex, …) following the shared
        harness under <code>prompts/</code>. Each summary records which agent wrote it via the
        <code>written_by</code> frontmatter field. The harness lives in <code>AGENTS.md</code> and
        <code>prompts/conference-overview.md</code> — readable by any agent, not tied to one vendor.
      </p>
      <p>
        Every page is available in English and 简体中文; switch at the top-right of the navbar.
      </p>
    </section>
  ) : (
    <section class="prose">
      <p>
        <strong>read-the-syspapers</strong> 是一个个人静态网站，汇集系统方向顶级会议（OSDI、SOSP、
        NSDI、ATC、EuroSys、ASPLOS、FAST、MLSys 等）的博士级论文综述。
      </p>
      <p>
        所有综述由编程智能体（Claude Code、Codex 等）按照 <code>prompts/</code> 下的统一流程生成，
        并通过 <code>written_by</code> 字段记录由哪个智能体完成。整套流程位于 <code>AGENTS.md</code>
        与 <code>prompts/conference-overview.md</code>，可被任意智能体直接读取，并不绑定特定厂商。
      </p>
      <p>
        所有页面均提供英文与简体中文双语，可通过导航栏右上角切换。
      </p>
    </section>
  )}
</BaseLayout>
