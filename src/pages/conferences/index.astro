---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ConferenceCard from "../../components/ConferenceCard.astro";

const conferences = await getCollection("conferences");
const papers = await getCollection("papers");

const paperCountByConf: Record<string, number> = {};
for (const p of papers) {
  const confId = p.data.conference.id;
  paperCountByConf[confId] = (paperCountByConf[confId] ?? 0) + 1;
}

conferences.sort((a, b) => {
  if (a.data.year !== b.data.year) return b.data.year - a.data.year;
  return a.data.venue.localeCompare(b.data.venue);
});
---

<BaseLayout title="Conferences">
  <h1>Conferences</h1>
  <p class="meta">All venues, most recent first.</p>
  <div class="grid">
    {conferences.map((c) => (
      <ConferenceCard
        id={c.id}
        venue={c.data.venue}
        year={c.data.year}
        title={c.data.title}
        overviewStatus={c.data.overview_status}
        paperCount={paperCountByConf[c.id] ?? 0}
      />
    ))}
  </div>
</BaseLayout>
