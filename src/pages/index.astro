---
import { DEFAULT_LANG, homeHref } from "../lib/paths";
const target = homeHref(DEFAULT_LANG);
---
<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={target} />
    <title>read-the-syspapers</title>
  </head>
  <body>
    <p>Redirecting to <a href={target}>{target}</a>.</p>
    <script set:html={`window.location.replace(${JSON.stringify(target)});`}></script>
  </body>
</html>
