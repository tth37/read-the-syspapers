---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PaperCard from "../../components/PaperCard.astro";

export async function getStaticPaths() {
  const papers = await getCollection("papers");
  const tagSet = new Set<string>();
  for (const p of papers) for (const t of p.data.tags) tagSet.add(t);
  return Array.from(tagSet).map((tag) => ({ params: { tag } }));
}

const { tag } = Astro.params;
const papers = (await getCollection("papers")).filter((p) => p.data.tags.includes(tag!));
papers.sort((a, b) => b.data.summary_date.getTime() - a.data.summary_date.getTime());

function paperSlug(id: string): string {
  const parts = id.split("/");
  return parts[parts.length - 1];
}
---

<BaseLayout title={`#${tag}`}>
  <h1>#{tag}</h1>
  <p class="meta">{papers.length} paper{papers.length === 1 ? "" : "s"} tagged <code>{tag}</code></p>
  <ul class="paper-list">
    {papers.map((p) => (
      <PaperCard
        conferenceId={p.data.conference.id}
        slug={paperSlug(p.id)}
        title={p.data.title}
        authors={p.data.authors}
        affiliations={p.data.affiliations}
        tags={p.data.tags}
        star={p.data.star}
        writtenBy={p.data.written_by}
        summaryDate={p.data.summary_date}
      />
    ))}
  </ul>
</BaseLayout>
