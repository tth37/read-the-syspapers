---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { tagHref } from "../../lib/paths";

const papers = await getCollection("papers");
const counts = new Map<string, number>();
for (const p of papers) {
  for (const t of p.data.tags) counts.set(t, (counts.get(t) ?? 0) + 1);
}
const tags = Array.from(counts.entries()).sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
---

<BaseLayout title="Tags">
  <h1>Tags</h1>
  {tags.length === 0 ? (
    <p class="meta">No tags yet — summaries haven't been generated.</p>
  ) : (
    <div class="tag-cloud">
      {tags.map(([t, n]) => (
        <a class="chip" href={tagHref(t)}>#{t} <span class="meta">({n})</span></a>
      ))}
    </div>
  )}
</BaseLayout>
